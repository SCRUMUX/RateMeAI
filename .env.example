# --- API_BASE_URL (важно для медиа в Telegram) ---
# app и worker: укажите ПУБЛИЧНЫЙ URL API (https://...), по которому Telegram сможет скачать
#   файлы из /storage/... (карточки рейтинга, сгенерированные CV/emoji). Localhost не виден Telegram.
# bot (docker-compose): в compose обычно переопределяется на http://app:8000 для запросов к API внутри сети.
# См. README.md — таблица «Компонент / Что должен видеть».

# === Telegram ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# === OpenRouter (LLM) ===
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# === Database ===
DATABASE_URL=postgresql+asyncpg://ratemeai:ratemeai@localhost:5432/ratemeai

# === Redis ===
REDIS_URL=redis://localhost:6379/0
# API stages each upload here for the worker (must be the same Redis as ARQ)
TASK_INPUT_REDIS_TTL_SECONDS=3600

# === Storage ===
# local: общий volume между app/worker/bot (см. docker-compose). В облаке без общего диска — s3.
# В docker-compose путь принудительно /app/storage для всех сервисов (игнор Windows-путей из .env).
# WORKER: при отсутствии файла на диске — запрос к API /storage/... (в compose задаётся автоматически).
STORAGE_HTTP_FALLBACK_BASE=
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ratemeai
S3_REGION=auto
# Публичный базовый URL объектов (CDN / public bucket) или пусто для presigned URL
S3_PUBLIC_BASE_URL=
# TTL presigned ссылок; держите с запасом до показа результата пользователю
S3_PRESIGN_TTL_SECONDS=3600

# Image generation for CV/dating/social/emoji:
#   mock | reve | replicate | fal_flux | fal_flux2 | auto
# Актуальный default — fal_flux2 (FLUX.2 [pro] edit через FAL.ai, ~$0.045/img
# при 2 МП, edit-mode с preservation лица, ``image_size`` до 4 МП).
# fal_flux (Kontext Pro, $0.04/img, 1 МП) оставлен на 1 релиз как rollback —
# переключается одной ENV переменной без передеплоя.
# auto — fal_flux2 при FAL_API_KEY, иначе Reve при REVE_API_TOKEN, иначе mock/ошибка.
# Replicate зарезервирован в docs/architecture/reserved.md и в auto не подключается.
IMAGE_GEN_PROVIDER=fal_flux2

# === FAL.ai (основной image-gen провайдер) ===
# Получить ключ: https://fal.ai → Dashboard → Keys (формат: <uuid>:<secret>).
# НИКОГДА не коммитить реальный ключ — .env игнорируется git'ом, храним только здесь.
# При ротации / компрометации ключа — сразу удалять его в FAL Dashboard → Keys → Revoke.
# Один и тот же FAL_API_KEY используется и для flux_flux2 (FLUX.2 Pro Edit),
# и для fal_flux (Kontext Pro rollback-target).
FAL_API_KEY=

# --- FLUX.2 Pro Edit (active, default) ---
# $0.03 за первый МП + $0.015 за каждый дополнительный (до 4 МП).
# Целевой выход — 2 МП портрет ≈ $0.045/фото; фактический размер
# резолвится per-style через StyleSpec.output_aspect.
FAL2_MODEL=fal-ai/flux-2-pro/edit
FAL2_OUTPUT_MP=2.0

# --- FLUX.1 Kontext Pro (legacy rollback-target) ---
# Фиксированная цена $0.04/img, жёсткий потолок ~1 МП, не принимает
# image_size. Для более дорогого Kontext Max: FAL_MODEL=fal-ai/flux-pro/kontext/max
FAL_MODEL=fal-ai/flux-pro/kontext

# --- Общие FAL-параметры (применимы к обоим моделям) ---
FAL_API_HOST=https://queue.fal.run
FAL_GUIDANCE_SCALE=3.5
FAL_SAFETY_TOLERANCE=2
FAL_OUTPUT_FORMAT=jpeg
FAL_MAX_RETRIES=2
FAL_REQUEST_TIMEOUT=180
FAL_POLL_INTERVAL=1.5

# === Reve (legacy runtime провайдер — переведён в fallback роль) ===
# Оставляем настроенным для режима IMAGE_GEN_PROVIDER=reve и для auto-fallback.
# Rotate token if it was ever exposed; never commit real token.
# Active runtime uses /v1/image/edit only; aspect ratio / test-time-scaling
# are handled locally or provider-side, not passed to the Reve REST body.
REVE_API_TOKEN=your-reve-api-token
REVE_API_HOST=https://api.reve.com
REVE_VERSION=latest
# Сколько HTTP-вызовов Reve на одну generate(). Ретраим ТОЛЬКО небиллящиеся
# исходы: 429 (rate-limit) и 5xx/сетевые сбои. 4xx/content-policy/пр. — fail
# сразу. 2 = максимум один ретрай поверх основного вызова (успешный ответ
# биллится один раз).
REVE_MAX_RETRIES=2

# Replicate (temporarily disabled; leave keys empty)
REPLICATE_API_TOKEN=
REPLICATE_MODEL_VERSION=

# === YooKassa Payments ===
# Shop ID и секретный ключ из личного кабинета ЮKassa
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
# URL возврата после оплаты (по умолчанию ссылка на бота)
YOOKASSA_RETURN_URL=https://t.me/RateMeAIBot
# Пакеты кредитов: количество:цена_руб через запятую
# Must match web Pricing.tsx: 1 фото 59₽, 5 фото 199₽, 15 фото 499₽, 30 фото 899₽
CREDIT_PACKS=1:59,5:199,15:499,30:899

# B2B admin bootstrap (set ADMIN_SECRET to enable POST /api/v1/auth/api-client)
ADMIN_SECRET=
API_KEY_PEPPER=

# === Identity Gate (VLM-based, no local face embeddings) ===
# Identity match is scored 0-10 by the quality-gate VLM comparing
# original vs generated. Hard gate = identity_match_threshold (images
# below are marked quality_warning). Soft warning boundary below.
IDENTITY_MATCH_THRESHOLD=7.0
IDENTITY_MATCH_SOFT_THRESHOLD=5.0

# v1.17 — VLM-driven identity retry. When the first FLUX pass returns
# identity_match < IDENTITY_MATCH_THRESHOLD, re-run generate() with a
# fresh seed up to IDENTITY_RETRY_MAX_ATTEMPTS extra times and keep
# whichever candidate has the higher score. Safe default ON —
# adds ~$0.007 avg spend at a 15% trigger rate.
IDENTITY_RETRY_ENABLED=true
IDENTITY_RETRY_MAX_ATTEMPTS=1

# v1.17 — GFPGAN face pre-clean. When ON, run fal-ai/gfpgan on
# clearly-blurry inputs (Laplacian thresholds in
# src/services/face_prerestore.py) before the main FLUX pass.
# Costs ~$0.002 per *applied* case. v1.17.1: default ON — the adaptive
# 1 MP full-body branch depends on downstream upscaling, so keeping
# this disabled left blurry inputs strictly worse. Provider failures
# fold back to the original bytes — never load-bearing.
GFPGAN_PRECLEAN_ENABLED=true
GFPGAN_MODEL=fal-ai/gfpgan
MODEL_COST_FAL_GFPGAN=0.002

# v1.17 — Real-ESRGAN final upscale. When ON, replace the local PIL
# LANCZOS x2 upscale in _apply_local_postprocess with a diffusion-aware
# fal-ai/real-esrgan pass (only when face_area_ratio >= 0.15).
# LANCZOS remains the automatic fallback on any provider failure.
# Costs ~$0.002 per applied case. v1.17.1: default ON — without it the
# adaptive 1 MP full-body branch produces visibly softer faces than the
# previous 2 MP LANCZOS path.
REAL_ESRGAN_ENABLED=true
REAL_ESRGAN_MODEL=fal-ai/real-esrgan
MODEL_COST_FAL_REAL_ESRGAN=0.002

# === v1.18 Hybrid Image-Gen Pipeline (PuLID + Seedream + CodeFormer) ===
# Strategy selector for the image-gen factory (v1.19 default: hybrid):
#   legacy      — use IMAGE_GEN_PROVIDER alone (v1.17 rollback).
#   hybrid      — StyleRouter: PuLID (identity_scene) +
#                 Seedream v4 Edit (scene_preserve) + FLUX.2 Pro Edit
#                 fallback. Average cost target ~$0.020/photo.
#   pulid_only  — route everything through PuLID.
IMAGE_GEN_STRATEGY=hybrid

# PuLID — https://fal.ai/models/fal-ai/pulid
# Identity-conditioned text-to-image. Takes a tight face crop + prompt
# and generates a new scene with the face locked in.
#
# v1.19 quality preset — 25 steps, CFG 3.5, id_scale 1.0. The previous
# Lightning preset (4 steps, CFG 1.2, id_scale 0.8) was the direct
# cause of duplicate-subject / "floating body" / generic-face
# regressions on v1.18. Cost rises from ~$0.006 to ~$0.015 per image,
# but every kadr is usable now.
PULID_ENABLED=true
PULID_MODEL=fal-ai/pulid
PULID_ID_SCALE=1.0
PULID_STEPS=25
PULID_GUIDANCE_SCALE=3.5
# Keep ``fidelity`` — "extreme style" is NOT an identity-preserving
# mode. The retry path also stays on fidelity (see PULID_RETRY_*).
PULID_MODE=fidelity
# NOTE: ``PULID_MAX_SEQUENCE_LENGTH`` was briefly set in v1.19.0 on the
# false assumption that PuLID inherits the FLUX.1 T2I schema. It does
# not — fal-ai/pulid returns HTTP 422 if that field is present.
# Removed in v1.19.1. Do not re-add.
# Retry-escalation knobs used when the VLM identity gate fails.
PULID_RETRY_ID_SCALE=1.2
PULID_RETRY_STEPS=35
PULID_RETRY_GUIDANCE_SCALE=5.0
MODEL_COST_FAL_PULID=0.015

# Seedream v4 Edit — https://fal.ai/models/fal-ai/bytedance/seedream/v4/edit
# Image-to-image edit up to 4 MP. Used for styles that must preserve
# the original photo's background / composition (docs, CV, emoji).
SEEDREAM_ENABLED=true
SEEDREAM_MODEL=fal-ai/bytedance/seedream/v4/edit
# ``standard`` (default, tighter) | ``fast`` (more aggressive rewrite).
SEEDREAM_ENHANCE_PROMPT_MODE=standard
MODEL_COST_FAL_SEEDREAM=0.03

# CodeFormer — https://fal.ai/models/fal-ai/codeformer
# Post-generation face polish.
#
# v1.19 policy: only runs for scene_preserve outputs (Seedream
# edits), only when the face is large, only on the first attempt.
# PuLID 25-step outputs are sharp enough to skip polish entirely,
# and polishing them was nudging identity off.
CODEFORMER_ENABLED=true
CODEFORMER_MODEL=fal-ai/codeformer
# v1.19: 0.85 = close to input, smooths artefacts without reshaping.
CODEFORMER_FIDELITY=0.85
# v1.19: no upscale inside CodeFormer — Real-ESRGAN handles that.
CODEFORMER_UPSCALE_FACTOR=1.0
# Skip polish for tiny faces (invisible + expensive).
CODEFORMER_MIN_FACE_RATIO=0.05
# Off for identity_scene (PuLID); on for scene_preserve (Seedream).
CODEFORMER_FOR_IDENTITY_SCENE=false
# Off on retry attempts — retries are about identity, not sharpness.
CODEFORMER_ON_RETRY=false
MODEL_COST_FAL_CODEFORMER_PER_MP=0.0021

# Legacy prompt_strength (unused in edit mode, kept for replicate fallback)
IMAGE_GEN_STRENGTH=0.45

# === Multi-pass Pipeline ===
# IMPORTANT: keep SEGMENTATION_ENABLED=false. Reve SDK 0.1.2 does not accept
# ``mask_image`` and will raise TypeError if segmentation is enabled. Multi-pass
# is intentionally off so every task fits into one Reve call — see
# src/config.py::segmentation_enabled for the full rationale.
SEGMENTATION_ENABLED=false
PIPELINE_BUDGET_MAX_USD=0.15

# === Quality Gates ===
AESTHETIC_THRESHOLD=6.0
# config.py default is 0.15; set lower for stricter artifact detection
ARTIFACT_THRESHOLD=0.15
PHOTOREALISM_ENABLED=true
PHOTOREALISM_THRESHOLD=0.5

# === Model Cost Estimates (USD per call) ===
MODEL_COST_REVE=0.02
MODEL_COST_REPLICATE=0.05

# Replicate inpainting model version (FLUX-inpaint); leave empty to skip inpaint steps
REPLICATE_INPAINT_MODEL_VERSION=

# === Scoring ===
SCORING_TEMPERATURE=0.0
# Number of LLM calls to average for scoring (1 = single call, 3 = consensus)
SCORING_CONSENSUS_SAMPLES=1

# === Rate Limits ===
RATE_LIMIT_DAILY=3
# Telegram username(s) без дневного лимита, через запятую, без @
RATE_LIMIT_EXEMPT_USERNAMES=scrumux

# === OK Mini App ===
OK_APP_ID=
OK_APP_SECRET_KEY=
OK_APP_PUBLIC_KEY=

# === VK Mini App ===
VK_APP_ID=
VK_APP_SECRET=
VK_SERVICE_TOKEN=

# === Yandex ID OAuth ===
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# === VK ID OAuth (web site login) ===
VK_ID_APP_ID=
VK_ID_APP_SECRET=

# === Google OAuth (foreign users, main domain only) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Phone SMS OTP ===
# Provider: log (dev, prints to console) | sms_aero | twilio
SMS_PROVIDER=log
SMS_AERO_API_KEY=
SMS_AERO_EMAIL=
SMS_AERO_SIGN=AI Look

# === WhatsApp Business API ===
WHATSAPP_API_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# === Sessions ===
# TTL for Bearer session tokens (web / mini apps), seconds
SESSION_TTL_SECONDS=86400

# === Geo-split Deployment ===
# Mode: primary (Railway, full AI processing) | edge (RU server, proxies AI to Railway)
DEPLOYMENT_MODE=primary
# Explicit product/runtime topology (recommended to set in every deployed service)
# MARKET_ID: global | ru | ...
MARKET_ID=global
# SERVICE_ROLE: api | worker | bot | web
SERVICE_ROLE=api
# COMPUTE_MODE: local | remote
COMPUTE_MODE=local
# URL of the primary Railway API (only needed in edge mode)
REMOTE_AI_BACKEND_URL=
# Shared secret for /internal/* endpoints between edge↔primary (set on BOTH servers)
INTERNAL_API_KEY=
# URL of the RU edge server — bot on Railway uses it for payments/balance (set on Railway bot service)
EDGE_API_URL=

# === RU Edge Auto-deploy (GitHub Actions secrets) ===
# Set these as GitHub repository secrets for automated RU deploys on push to main:
#   RU_SSH_HOST  — IP or hostname of the RU edge server
#   RU_SSH_USER  — SSH username (e.g. root)
#   RU_SSH_KEY   — Private SSH key (ed25519 or rsa) for passwordless access
# If RU_SSH_HOST or RU_SSH_KEY are missing, the deploy-ru job is skipped gracefully.

# === CORS ===
# Extra allowed origins for mini apps (comma-separated). Auto-added to CORS in prod.
CORS_EXTRA_ORIGINS=

# === App ===
# Необязательно: короткий SHA коммита (в CI), смотреть в GET /health и в логах при старте
DEPLOY_GIT_SHA=
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
API_BASE_URL=http://localhost:8000
# Public URL of the web SPA (for share links, payment return URLs)
WEB_BASE_URL=https://ailookstudio.ru

# === Web App (Vite SPA) ===
# API endpoint the frontend calls (set in Railway web service env)
VITE_API_BASE_URL=https://api.ailookstudio.ru
# Explicit market for frontend build. If empty, web falls back to hostname detection.
VITE_MARKET_ID=global
# Custom domain for the web service
WEB_DOMAIN=ailookstudio.ru
TELEGRAM_BOT_USERNAME=YourBotUsername
BOT_WEBHOOK_URL=
BOT_WEBHOOK_SECRET=
