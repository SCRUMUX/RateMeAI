# ============================================================
# RU Edge Server Environment (.env.ru)
# ============================================================
# Copy to .env.ru and fill in the values before deploying.
# This server runs in EDGE mode: handles auth, user data, and
# payments locally; proxies AI generation to the primary Railway backend.
# ============================================================

# --- Geo-split (REQUIRED) ---
DEPLOYMENT_MODE=edge
REMOTE_AI_BACKEND_URL=https://app-production-XXXX.up.railway.app
INTERNAL_API_KEY=your-shared-secret-between-edge-and-primary

# --- Database (local PostgreSQL on RU server) ---
POSTGRES_USER=ratemeai
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=ratemeai

# --- API ---
APP_ENV=prod
API_BASE_URL=https://ru.ailookstudio.ru
WEB_BASE_URL=https://ru.ailookstudio.ru

# --- Frontend build ---
VITE_API_BASE_URL=https://ru.ailookstudio.ru

# --- YooKassa Payments (works from RU) ---
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_RETURN_URL=https://ru.ailookstudio.ru
CREDIT_PACKS=1:59,5:199,15:499,30:899

# --- Sessions ---
SESSION_TTL_SECONDS=86400

# --- Auth providers (fill in as needed) ---
# Yandex ID OAuth
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# VK ID OAuth
VK_ID_APP_ID=
VK_ID_APP_SECRET=

# VK Mini App
VK_APP_ID=
VK_APP_SECRET=
VK_SERVICE_TOKEN=

# OK Mini App
OK_APP_ID=
OK_APP_SECRET_KEY=
OK_APP_PUBLIC_KEY=

# Phone SMS OTP
SMS_PROVIDER=sms_aero
SMS_AERO_API_KEY=
SMS_AERO_EMAIL=
SMS_AERO_SIGN=AI Look

# Telegram bot (optional, can keep on Railway only)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# --- CORS ---
CORS_EXTRA_ORIGINS=

# --- NOTE: The following are NOT needed on the edge server ---
# OPENROUTER_API_KEY — AI processing is on Railway
# REVE_API_TOKEN — AI processing is on Railway
# REPLICATE_API_TOKEN — AI processing is on Railway
